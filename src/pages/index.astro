  'Stats',
  'Movimientos',
  'Debilidades',
  'Fortalezas',
  'Inmunidades',
  'Evolucion',
  'Fotos',
  'Curiosidades',
];

const overlayThemes = [
  ['Predeterminado', 'Base oscura y limpia para lectura rapida.', 'media/overlay-theme-default.jpg', 1812, 2176],
  ['Purpura', 'Estetica energica con panel translucido.', 'media/overlay-theme-purple.jpg', 1812, 2176],
  ['Pokemon X', 'Azul electrico con borde frio y tecnico.', 'media/overlay-theme-x.jpg', 1812, 2176],
  ['Pokemon Y', 'Coral intenso con caracter agresivo.', 'media/overlay-theme-y.jpg', 1812, 2176],
  ['Zafiro', 'Azul cristal para un look mas elegante.', 'media/overlay-theme-sapphire.jpg', 1812, 2176],
